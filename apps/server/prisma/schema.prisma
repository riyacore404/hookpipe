generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  passwordHash String    @map("password_hash")
  createdAt DateTime @updatedAt @map("created_at") @db.Timestamptz

  organisations OrganisationMember[]
  apiKeys       ApiKey[]

  @@map("users")
}

model Organisation {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  members  OrganisationMember[]
  projects Project[]

  @@map("organisations")
}

model OrganisationMember {
  id             String   @id @default(uuid())
  organisationId String   @map("organisation_id")
  userId         String   @map("user_id")
  role           String   @default("member") // owner | admin | member
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organisation Organisation @relation(fields: [organisationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([organisationId, userId])
  @@index([userId])
  @@map("organisation_members")
}

model Project {
  id             String   @id @default(uuid())
  organisationId String   @map("organisation_id")
  name           String
  environment    String   @default("development") // production | staging | development
  ingestKey      String   @unique @default(uuid()) @map("ingest_key")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organisation Organisation @relation(fields: [organisationId], references: [id])
  events       Event[]
  destinations Destination[]

  @@index([organisationId])
  @@map("projects")
}

model Event {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  payload    Json
  headers    Json?
  sourceIp   String?  @map("source_ip")
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz

  project           Project           @relation(fields: [projectId], references: [id])
  deliveryAttempts  DeliveryAttempt[]

  @@index([projectId])
  @@index([ingestedAt(sort: Desc)])
  @@map("events")
}

model Destination {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  url       String
  label     String?
  secret    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  project          Project          @relation(fields: [projectId], references: [id])
  deliveryAttempts DeliveryAttempt[]
  filterRules      FilterRule[]

  @@index([projectId])
  @@map("destinations")
}

model DeliveryAttempt {
  id            String   @id @default(uuid())
  eventId       String   @map("event_id")
  destinationId String   @map("destination_id")
  status        String   @default("pending") // pending | success | failed | dead
  httpStatus    Int?     @map("http_status")
  responseBody  String?  @map("response_body")
  latencyMs     Int?     @map("latency_ms")
  attemptNumber Int      @default(1) @map("attempt_number")
  attemptedAt   DateTime @default(now()) @map("attempted_at") @db.Timestamptz

  event       Event       @relation(fields: [eventId], references: [id])
  destination Destination @relation(fields: [destinationId], references: [id])

  @@index([eventId])
  @@index([destinationId])
  @@index([status])
  @@index([attemptedAt(sort: Desc)])
  @@map("delivery_attempts")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  keyHash    String    @unique @map("key_hash")
  label      String?
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model FilterRule {
  id            String @id @default(uuid())
  destinationId String @map("destination_id")
  field         String
  operator      String // equals | contains | gt | lt
  value         String

  destination Destination @relation(fields: [destinationId], references: [id])

  @@index([destinationId])
  @@map("filter_rules")
}